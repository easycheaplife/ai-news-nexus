# 采集器上报数据的后端 API 地址
# 如果后端运行在远程服务器，请将 localhost 修改为服务器的实际 IP
SCRAPER_API_URL=http://localhost:8000

# Gemini AI 配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite,gemini-3.1-flash-lite-preview,gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-2.0-flash,gemini-flash-latest

# Product Hunt API Token (用于绕过 Cloudflare 并获取完整长篇正文)
# 申请地址: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_TOKEN=your_producthunt_developer_token_here

# 抓取配置
# 仅抓取最近 X 小时内的内容，防止一次性抓取过多历史数据 (默认 72)
SCRAPE_WINDOW_HOURS=72

# Twitter 防护机制：触发 429 错误的最大允许次数。超过此阈值将直接终止抓取该平台。
TWITTER_MAX_429_ERRORS=10

# 信源审计配置
# 一个账号持续 X 天完全没产出有效内容则自动下线 (默认 15)
MAX_SILENCE_DAYS=15

# 发现引擎配置：单次运行最多验证(Vetting)的新账号数量。防止消耗过多 AI API 额度。
DISCOVERY_MAX_VETTING=100

# 全局配置：系统中允许激活的最大采集账号总数。达到此上限后，发现引擎将停止晋升新账号。
MAX_ACTIVE_TARGETS=100

# 网络代理配置 (如果访问 Twitter/Reddit 遇到连接问题时使用)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 抓取冷却期（小时）。距离上次成功抓取不到该时间的账号将被跳过。默认 1 小时。
TWITTER_SCRAPE_INTERVAL_HOURS=1.0
