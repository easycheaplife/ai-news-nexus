# 前端开发服务器配置
VITE_HOST=0.0.0.0
VITE_PORT=5173

# 后端 API 地址
# 本地开发使用: http://localhost:8000
# Netlify 部署使用: /api (配合 netlify.toml 代理)
VITE_API_URL=/api

# 资讯过滤配置 (最低显示分数)
VITE_MIN_SCORE=60

# 资讯正文显示行数 (最少显示的行数)
VITE_CONTENT_LINES=5

# 后端真实 IP 地址 (用于构建时注入 _redirects)
# 仅用于本地构建或在 Netlify 环境变量中配置，不要提交包含真实 IP 的 .env 文件
BACKEND_URL=http://your-server-ip:8000

